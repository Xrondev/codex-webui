{
  "name": "codex-webui",
  "version": "1.0.0",
  "description": "A minimal Codex Web UI that wraps the local Codex CLI.",
  "private": true,
  "scripts": {
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "NODE_ENV=production node dist-server/index.js",
    "setup": "./scripts/install.sh",
    "service:install": "./scripts/install-service.sh",
    "service:uninstall": "./scripts/uninstall-service.sh",
    "service:start": "systemctl --user start codex-webui",
    "service:stop": "systemctl --user stop codex-webui",
    "service:restart": "systemctl --user restart codex-webui",
    "service:status": "systemctl --user status codex-webui --no-pager",
    "service:logs": "journalctl --user -u codex-webui -f"
  },
  "keywords": [
    "codex",
    "webui",
    "terminal"
  ],
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.20.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
